[Unit]
Description=Librescoot Alarm Service
After=network.target redis.service librescoot-motion.service
Wants=redis.service librescoot-motion.service

[Service]
Type=simple
ExecStart=/usr/bin/alarm-service \
    --redis=localhost:6379 \
    --log-level=info
Restart=always
RestartSec=5
User=root
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target